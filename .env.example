# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/deep_claw
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=deep_claw

# LLM（智谱 OpenAI 兼容）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OPENAI_MODEL=glm-4-plus

# Tavily（深度调研）
TAVILY_API_KEY=

# LangSmith（可选）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=deep-claw

# CORS
CORS_ORIGINS=*

# Frontend（浏览器访问后端的地址；Docker 默认映射到本机 8000）
NEXT_PUBLIC_API_BASE=http://localhost:8000
